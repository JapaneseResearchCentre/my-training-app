import sqlite3
from datetime import datetime
import pandas as pd

def init_db():
    """データベースとテーブルの初期化"""
    conn = sqlite3.connect('training_log.db')
    cursor = conn.cursor()
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS logs (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            date TEXT,
            weight REAL,
            menu TEXT
        )
    ''')
    conn.commit()
    conn.close()

def add_log(weight, menu):
    """データの追加"""
    conn = sqlite3.connect('training_log.db')
    cursor = conn.cursor()
    date = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
    cursor.execute('INSERT INTO logs (date, weight, menu) VALUES (?, ?, ?)', (date, weight, menu))
    conn.commit()
    conn.close()
    print(f"\n記録完了: {date}")

def show_logs():
    """データの表示（Pandasを使用して綺麗に出力）"""
    conn = sqlite3.connect('training_log.db')
    df = pd.read_sql_query("SELECT * FROM logs", conn)
    conn.close()
    if df.empty:
        print("\nまだデータがありません。")
    else:
        print("\n--- トレーニング履歴 ---")
        print(df.to_string(index=False))

def main():
    init_db()
    while True:
        print("\n1: 記録する | 2: 履歴を見る | 3: 終了")
        choice = input("選択してください: ")

        if choice == '1':
            try:
                weight = float(input("体重(kg)を入力: "))
                menu = input("トレーニングメニューを入力: ")
                add_log(weight, menu)
            except ValueError:
                print("体重は数値で入力してください。")
        elif choice == '2':
            show_logs()
        elif choice == '3':
            print("プログラムを終了します。")
            break
        else:
            print("無効な選択です。")

if __name__ == "__main__":
    main()